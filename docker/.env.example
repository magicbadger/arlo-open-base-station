# docker/.env — environment variables for Docker Compose
# Copy to docker/.env and fill in real values, OR run setup.sh to generate automatically.
# This file is NOT committed to git (add docker/.env to .gitignore).

# Your Windows PC's WiFi IP address (find with: ipconfig | findstr "IPv4")
HOST_IP=192.168.1.50

# Web UI login password (no spaces or quote characters)
AUTH_PASSWORD=changeme

# Random 32-byte hex secrets — generate with: openssl rand -hex 32
AUTH_SECRET=replace_with_32_random_hex_chars
THUMBNAIL_SECRET=replace_with_32_random_hex_chars
